# Normalisation des fins de ligne
* text=auto

# Code: toujours LF (Unix)
*.py   text eol=lf
*.sh   text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sql  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf

# Scripts Windows: CRLF
*.ps1  text eol=crlf
*.bat  text eol=crlf
